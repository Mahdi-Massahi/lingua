# ── Agent backend ─────────────────────────────────────────────────────────────
# 'local' = adk web / Cloud Run (default)
# 'agent_engine' = Vertex AI Agent Engine
ADK_BACKEND=local

# Local / Cloud Run mode
ADK_URL=http://localhost:8080
ADK_APP_NAME=lingua

# Agent Engine mode
# GOOGLE_CLOUD_PROJECT=your-project-id
# GOOGLE_CLOUD_LOCATION=europe-west4
# REASONING_ENGINE_ID=your-engine-id

# ── Firebase (client-side, not secret) ────────────────────────────────────────
# Get these from: Firebase Console → Project Settings → Your apps → Config
VITE_FIREBASE_API_KEY=
VITE_FIREBASE_AUTH_DOMAIN=
VITE_FIREBASE_PROJECT_ID=
VITE_FIREBASE_STORAGE_BUCKET=
VITE_FIREBASE_MESSAGING_SENDER_ID=
VITE_FIREBASE_APP_ID=
